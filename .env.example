# Copy to .env and fill in, or set these in Colab Secrets

# HuggingFace token — for downloading models & datasets
# Get: https://huggingface.co/settings/tokens  (read access is enough)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token — for pushing from Colab
# Get: https://github.com/settings/tokens  (classic, scope: repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-username
